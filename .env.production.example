# ── Envirr LMS — Production Environment Template ──────────────────────────────
# Copy this file to .env.production and fill in every value before deploying.
# .env.production is gitignored — never commit real secrets.
#
# Generate a SECRET_KEY with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"


# ── Django core ────────────────────────────────────────────────────────────────

DEBUG=False

# Must be a long random string — NOT the django-insecure-* placeholder.
SECRET_KEY=REPLACE_WITH_GENERATED_KEY

# Comma-separated list of your domain(s), e.g.: envirr.app,www.envirr.app
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Full public URL of the frontend (no trailing slash).
# Used in verification and password-reset email links.
FRONTEND_URL=https://yourdomain.com

# Allowed origins for CORS (must match FRONTEND_URL origin).
CORS_ALLOWED_ORIGINS=https://yourdomain.com


# ── Database ───────────────────────────────────────────────────────────────────
# When using docker-compose.deploy.yml, the bundled Postgres container is
# provisioned from POSTGRES_* below — keep them in sync with DATABASE_URL.
# (If you point at an external/managed DB, set DATABASE_URL only.)

POSTGRES_DB=envirr_db
POSTGRES_USER=envirr
POSTGRES_PASSWORD=STRONG_DB_PASSWORD

# Format: postgres://USER:PASSWORD@HOST:PORT/DB_NAME  (HOST=db for the bundled DB)
DATABASE_URL=postgres://envirr:STRONG_DB_PASSWORD@db:5432/envirr_db


# ── Redis / Celery ─────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379/1
CACHE_URL=redis://redis:6379/2


# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password):
# Google Account → Security → 2-Step Verification → App passwords

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-address@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=Envirr <your-address@gmail.com>


# ── AI / LLM ──────────────────────────────────────────────────────────────────

GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...

# AI Tutor runs on Gemini (uses GEMINI_API_KEY above). Optionally pin the model:
GEMINI_TUTOR_MODEL=gemini-2.0-flash


# ── Gunicorn tuning (optional) ────────────────────────────────────────────────
# Defaults: 3 workers, 2 threads, 120s timeout.
# Rule of thumb for workers: 2 * CPU_CORES + 1

# GUNICORN_WORKERS=3
# GUNICORN_THREADS=2
# GUNICORN_TIMEOUT=120


# ── Single-service / staging (Dockerfile.prod, SPA served same-origin) ────────
# When the prod image serves the built SPA itself (Render/Railway/Fly single
# service), the frontend and API share one origin — CORS_ALLOWED_ORIGINS and a
# separate FRONTEND_URL host aren't needed (set FRONTEND_URL to the same URL).

# Closed friends-test: let testers register without email verification.
# AUTO_VERIFY_USERS=True

# Run Celery tasks inline (no separate worker dyno on free tiers).
# CELERY_TASK_ALWAYS_EAGER=True

# Hosts terminate TLS at their proxy; keep redirect ON in real deploys.
# Set False only to smoke-test a prod image locally over http.
# SECURE_SSL_REDIRECT=True

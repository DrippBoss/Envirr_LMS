# ── Envirr LMS — Local Development Environment ───────────────────────────────
# The one-click runner (scripts/run.ps1 / run.sh) copies this to `.env` on first
# run. `.env` is gitignored — never commit real secrets.
#
# The app boots fine with the defaults below. AI features (tutor, paper gen,
# bulk ingestion) need real API keys — fill them in when you want those.

# ── Django core ──────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=django-insecure-replace-me-in-prod

# ── Database / Redis (match docker-compose.yml service names) ─────────────────
DATABASE_URL=postgres://postgres:postgres@db:5432/envirr_db
REDIS_URL=redis://redis:6379/1

# ── Local testing convenience ─────────────────────────────────────────────────
# Let new sign-ups log in without the email-verification step.
AUTO_VERIFY_USERS=True
# Run Celery tasks inline so paper-gen works without a separate worker.
CELERY_TASK_ALWAYS_EAGER=True

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── AI / LLM (optional — leave blank to run without AI features) ──────────────
GEMINI_API_KEY=
GROQ_API_KEY=
GEMINI_TUTOR_MODEL=gemini-2.0-flash

# ── Email (optional — only needed if AUTO_VERIFY_USERS=False) ─────────────────
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Envirr <noreply@envirr.app>

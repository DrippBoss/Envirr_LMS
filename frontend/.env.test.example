# Envirr LMS — Playwright test credentials
# Copy this file to `.env.test` (gitignored) and fill in real dev accounts.
#
#   cp .env.test.example .env.test
#
# Then run:  npm run test    (or the /intent-test skill)
#
# Any role left blank → that role's auth-required tests are SKIPPED (not failed),
# so you can run a partial suite with just the credentials you have.

# Where the running frontend is served (Vite dev server or prod preview).
ENVIRR_BASE_URL=http://127.0.0.1:5173

# Student account (drives dashboard, mock-test, ai-tutor specs)
ENVIRR_STUDENT_USER=
ENVIRR_STUDENT_PASS=

# Teacher account (drives teacher-panel checks in qa-audit)
ENVIRR_TEACHER_USER=
ENVIRR_TEACHER_PASS=

# Admin account (drives admin-dashboard spec)
ENVIRR_ADMIN_USER=
ENVIRR_ADMIN_PASS=
